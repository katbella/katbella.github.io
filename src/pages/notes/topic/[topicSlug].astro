---
import Layout from '../../../layouts/Layout.astro';
import NotesList from '../../../components/NotesList.astro';
import { TOPICS } from '../../../lib/taxonomy';
import {
  getNotesForTopic,
  getPublishedNotes,
  type NoteEntry,
} from '../../../lib/notes';

export async function getStaticPaths() {
  const notes = await getPublishedNotes();

  return TOPICS.map((topic) => ({
    params: { topicSlug: topic.slug },
    props: { notes: getNotesForTopic(notes, topic.slug) },
  }));
}

interface Props {
  notes: NoteEntry[];
}

const { notes } = Astro.props;
---

<Layout
  title="Kat Bella - Notes"
  description="Notes by Kat Bella."
  includePixel={false}
>
  <nav aria-label="Notes">
    <a href="/notes">Back to notes</a>
  </nav>
  <section>
    <h1>Notes</h1>
    <NotesList notes={notes} />
  </section>
</Layout>

<style>
  nav {
    margin-bottom: 2rem;
    font-size: 0.8rem;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
</style>
