---
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
  formatNoteDate,
  getNoteRssDescription,
  getPublishedNotes,
  type NoteEntry,
} from '../../lib/notes';

export async function getStaticPaths() {
  const notes = await getPublishedNotes();

  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

interface Props {
  note: NoteEntry;
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<Layout
  title={`Kat Bella - ${note.data.title}`}
  description={getNoteRssDescription(note)}
  includePixel={false}
>
  <nav aria-label="Notes">
    <a href="/notes">Back to notes</a>
  </nav>
  <article>
    <header>
      <h1>{note.data.title}</h1>
      <time datetime={note.data.publishedAt.toISOString().slice(0, 10)}>
        {formatNoteDate(note.data.publishedAt)}
      </time>
    </header>
    <div class="note-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  nav {
    margin-bottom: 2rem;
    font-size: 0.8rem;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  header {
    margin-bottom: 1.5rem;
  }

  time {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .note-body :global(h2) {
    font-size: 1.25rem;
    margin-block: 1.5rem 1rem;
  }

  .note-body :global(p) {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .note-body :global(a) {
    text-decoration: underline;
    text-underline-offset: 0.12em;
    text-decoration-thickness: 0.08em;
  }

  .note-body :global(.updated) {
    display: block;
    margin-top: 2rem;
    color: var(--text-muted);
    font-size: 0.8rem;
  }
</style>
