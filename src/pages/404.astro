---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kat Bella - Page not found" description="Page not found.">
  <section>
    <h1>404 - Page not found</h1>
    <p>
      Pixel has searched for it, too. You can go back <a href="/">home</a> or play
      ball with her for a bit if you wish.
    </p>
  </section>
</Layout>

<style>
  h1 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  p a {
    text-decoration: underline;
    text-underline-offset: 0.12em;
    text-decoration-thickness: 0.08em;
  }
</style>
