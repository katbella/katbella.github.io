---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kat Bella - About">
  <section>
    <h1>About</h1>
    <p>
      Software engineer with a lot of hobbies. I build software for
      professionals. For fun, I make games and compose music. Been building
      things on the internet since 2004, starting with Infinity Engine mods. <a
        href="https://www.instagram.com/pixel_doodle/"
        target="_blank"
        rel="noopener noreferrer">Pixel</a
      > is my dog.
    </p>
    <p>
      Artwork is by <a
        href="https://www.artstation.com/lorienpixel"
        target="_blank"
        rel="noopener noreferrer">LorienPixel</a
      >.
    </p>
  </section>
</Layout>

<style>
  h1 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  p a {
    text-decoration: underline;
    text-underline-offset: 0.12em;
    text-decoration-thickness: 0.08em;
  }
</style>
