---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Container from '../components/Container.astro';
import PixelDog from '../components/PixelDog.astro';

interface Props {
  title?: string;
  description?: string;
  includePixel?: boolean;
}

const {
  title = 'Kat Bella',
  description = 'Software engineer with a lot of hobbies.',
  includePixel = true,
} = Astro.props;

const pixelConsoleScript = [
  `console.log(${JSON.stringify(
    "Curious about Pixel's minigame? https://github.com/katbella/katbella.github.io",
  )});`,
  `console.log(${JSON.stringify(
    'Also, there may be a %ccheat mode%c.',
  )}, ${JSON.stringify('color: #00c853; font-weight: 700;')}, '');`,
].join('\n');
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Kat Bella Notes"
      href="/rss.xml"
    />
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    </script>
  </head>
  <body>
    {includePixel && <PixelDog />}
    <div class="crt-overlay" aria-hidden="true"></div>
    <Header showPixelControls={includePixel} />
    <main>
      <Container>
        <slot />
      </Container>
    </main>
    <Footer />
    {includePixel && <script is:inline set:html={pixelConsoleScript} />}
    <script src="../scripts/crt-mode.js"></script>
  </body>
</html>
